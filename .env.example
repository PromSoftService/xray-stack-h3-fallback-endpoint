############################################
# IMAGE VERSIONS
############################################

# Official Xray image tag.
XRAY_IMAGE=ghcr.io/xtls/xray-core:26.3.27

# HTTP/3-capable nginx image.
# Keep it pinned.
NGINX_IMAGE=macbre/nginx-http3:1.29.7

# Official Certbot image.
CERTBOT_IMAGE=certbot/certbot:latest


############################################
# DOMAIN / TLS
############################################

# Public domain pointed to this VPS.
DOMAIN=example.com

# Email for Let's Encrypt notices.
EMAIL=you@example.com


############################################
# XRAY INBOUND
############################################

# UUID for VLESS authentication.
XRAY_UUID=11111111-2222-3333-4444-555555555555

# Secret HTTP path used by xray transport.
XRAY_PATH=/secretxhttp

# Internal listen port inside Docker network.
XRAY_PORT=10000

# Xray log level: debug / info / warning / error / none
XRAY_LOGLEVEL=warning

# XHTTP mode.
XRAY_XHTTP_MODE=stream-one


############################################
# XRAY DNS / DOH
############################################

# DNS-over-HTTPS resolver used by Xray.
DOH_URL=https://1.1.1.1/dns-query


############################################
# NGINX / H3 / FALLBACK
############################################

# Keep H2 enabled for fallback.
NGINX_HTTP2=on

# Enable H3.
NGINX_HTTP3=on

# Alt-Svc max-age in seconds.
NGINX_ALTSVC_MAX_AGE=86400

# HSTS max-age in seconds.
NGINX_HSTS_MAX_AGE=31536000

# Upstream timeouts.
NGINX_PROXY_READ_TIMEOUT=3600s
NGINX_PROXY_SEND_TIMEOUT=3600s


############################################
# CHECKS
############################################

# yes / no
VERIFY_HTTP3_IMAGE=yes
